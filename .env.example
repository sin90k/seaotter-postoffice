# Sea Otter Post Office - 环境变量模板
# 复制此文件为 .env 并填入实际值

# Supabase（用户体系、明信片存储、埋点）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# 主流程：标题/正文/背面图（也可在管理员后台填写，优先使用）
# VITE_OPENAI_API_KEY=sk-...
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# 编辑时「改写」单字段（也可在管理员后台填写）
# VITE_GEMINI_API_KEY=your_gemini_key_here

# 管理员邮箱（与登录邮箱一致时显示「管理面板」入口；也可在 Supabase profiles 表将 role 设为 admin）
# VITE_ADMIN_EMAIL=admin@example.com

# 品牌信息（促销积分生成明信片背面水印，可选）
# VITE_BRAND_NAME=Sea Otter Post Office
# VITE_BRAND_NAME_ZH=海獭邮局
# VITE_BRAND_NAME_JA=ラッコ郵便局
# VITE_BRAND_NAME_KO=해달 우체국
# VITE_BRAND_DOMAIN=seaotter-postoffice.vercel.app
# VITE_BRAND_LOGO_URL=
